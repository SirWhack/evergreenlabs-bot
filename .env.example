# Copy to .env and fill in.

# GitHub
GITHUB_USERNAME=
GITHUB_TOKEN=                       # classic PAT with `repo` + `read:project` (the latter for Projects v2)
GITHUB_PROJECT_NUMBER=              # optional: Projects v2 board number to surface as roadmap

# Local LLM (OpenAI-compatible)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed              # most local servers ignore this; set to anything non-empty
LLM_MODEL=                          # e.g. "qwen2.5-coder-32b-instruct"

# Website repo (where siteData.js lives)
WEBSITE_REPO_PATH=/home/swynn/Code/evergreenlabs
WEBSITE_SITEDATA_REL=src/content/siteData.js

# Publish behavior
PUBLISH_GIT_COMMIT=true             # set false to skip auto-commit on publish
PUBLISH_GIT_PUSH=false              # set true to also push to remote

# Webhook-driven autorun (optional; required only for `bot poll-once`)
WORKER_URL=                         # e.g. https://evergreenlabs-bot-webhook.<sub>.workers.dev
BOT_POLL_TOKEN=                     # 32-byte hex; must match the BOT_POLL_TOKEN set on the Worker
